        "@tailwindcss/forms": "^0.5.10",
        "@types/node": "^24.5.2",
        "@vitejs/plugin-vue": "^6.0.1",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.9.2",
        "vite": "^7.1.7",
        "vitest": "^3.2.4",
        "vue-tsc": "^3.1.1"
    },
    "packageManager": "pnpm@10.28.2"
